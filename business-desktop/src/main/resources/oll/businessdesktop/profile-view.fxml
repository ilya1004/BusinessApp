<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<GridPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="oll.businessdesktop.ProfileController"
          styleClass="profile-root"
          hgap="10" vgap="10">
    <padding><Insets top="30" bottom="30" left="30" right="30"/></padding>

    <Label text="User Profile" styleClass="profile-title" GridPane.columnSpan="2"/>

    <VBox spacing="20" GridPane.rowIndex="1" GridPane.columnSpan="2" styleClass="profile-info">
        <Label fx:id="usernameLabel" styleClass="profile-field"/>
        <Label fx:id="nameLabel" styleClass="profile-field"/>
        <Label fx:id="roleLabel" styleClass="profile-field"/>
    </VBox>

    <HBox spacing="10" alignment="BOTTOM_RIGHT" GridPane.rowIndex="2" GridPane.columnSpan="2">
        <Button text="Refresh" onAction="#onRefresh" styleClass="profile-button"/>
        <Button text="Logout" onAction="#onLogout" styleClass="logout-button"/>
    </HBox>
</GridPane>
