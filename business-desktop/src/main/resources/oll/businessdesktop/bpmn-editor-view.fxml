<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.web.WebView?>
<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="oll.businessdesktop.BpmnEditorController">
    <top>
        <ToolBar fx:id="toolBar">
            <Button text="Новая диаграмма" onAction="#onNewDiagram"/>
            <Button text="Сохранить XML" onAction="#onSaveXML"/>
            <Separator/>
            <Button text="Открыть .bpmn" onAction="#onOpenFile"/>
            <Separator/>
            <Button text="Экспорт SVG" onAction="#onExportSVG"/>
            <Button text="Открыть папку SVG" onAction="#onOpenSvgFolder"/>
        </ToolBar>
    </top>
    <center>
        <WebView fx:id="webView"/>
    </center>
</BorderPane>
