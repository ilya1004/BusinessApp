<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="oll.businessdesktop.ProcessInstancesController">
    <top>
        <VBox spacing="8">
            <padding><Insets top="15" bottom="10" left="15" right="15"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Экземпляр:" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <ComboBox fx:id="instanceSelector" prefWidth="350" promptText="Выберите экземпляр..."/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label fx:id="statusLabel" style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;"/>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
            <VBox spacing="15" style="-fx-padding: 10;" maxWidth="Infinity">
                <VBox fx:id="diagramContainer" prefHeight="350" styleClass="panel-box" minHeight="350" maxHeight="350" maxWidth="Infinity">
                    <padding><Insets top="8" left="8" bottom="8" right="8"/></padding>
                    <Label text="Диаграмма процесса" style="-fx-font-size: 14px; -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="5"/></VBox.margin>
                    </Label>
                    <WebView fx:id="diagramViewer" prefHeight="320" maxWidth="Infinity" VBox.vgrow="NEVER"/>
                </VBox>
                <VBox fx:id="kpiCardsContainer" spacing="10" styleClass="panel-box" visible="false" maxWidth="Infinity">
                    <Label text="KPI экземпляра" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <HBox spacing="15">
                        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: -color-bg-subtle; -fx-padding: 15; -fx-background-radius: 6;">
                            <Label text="План" style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;"/>
                            <Label fx:id="kpiPlannedLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: -color-bg-subtle; -fx-padding: 15; -fx-background-radius: 6;">
                            <Label text="Факт" style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;"/>
                            <Label fx:id="kpiActualLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                        </VBox>

                    </HBox>
                </VBox>
                <VBox fx:id="infoContainer" spacing="8" styleClass="panel-box" maxWidth="Infinity">
                    <Label text="Информация об экземпляре" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <HBox fx:id="processInfoRows" spacing="20"/>
                </VBox>
                <VBox fx:id="tableContainer" spacing="8" styleClass="panel-box" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Задачи" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <TableView fx:id="taskTable" prefHeight="400" VBox.vgrow="ALWAYS" minHeight="300">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colName" text="Название" prefWidth="150"/>
                            <TableColumn fx:id="colStatus" text="Статус" prefWidth="120"/>
                            <TableColumn fx:id="colAssignee" text="Исполнитель" prefWidth="140"/>
                            <TableColumn fx:id="colDuration" text="Длительность (факт / план), ч" prefWidth="270"/>
                            <TableColumn fx:id="colActions" text="Действия" prefWidth="270"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>