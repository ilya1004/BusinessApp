<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<BorderPane fx:id="rootLayout" xmlns:fx="http://javafx.com/fxml"
            fx:controller="oll.businessdesktop.MainLayoutController"
            stylesheets="/styles/styles.css"
            styleClass="root">
    <!-- Main layout: sidebar left, content right -->
    <left>
        <VBox spacing="5" styleClass="sidebar" xmlns="http://javafx.com/fxml">
            <padding><Insets top="15" bottom="15" left="10" right="10"/></padding>
            <Button text="Редактор процессов" onAction="#onProcessDesignerTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Модели процессов" onAction="#onProcessViewTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Процессы" onAction="#onProcessInstancesTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Симуляция" onAction="#onSimulationTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Мои задачи" onAction="#onMyTasksTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Пользователи" onAction="#onUsersTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Организация" onAction="#onDepartmentsTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Логи" onAction="#onLogsTab" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="BPMN редактор" onAction="#onBpmnTab" maxWidth="Infinity" styleClass="sidebar-button"/>
        </VBox>
    </left>
    <!-- Content area with top bar -->
    <center>
        <BorderPane fx:id="contentContainer" xmlns="http://javafx.com/fxml" styleClass="content-container">
            <top>
                <HBox spacing="10" styleClass="top-bar">
                    <padding><Insets top="10" bottom="10" left="15" right="15"/></padding>
                    <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                        <Label fx:id="pageTitle" text="BPMN Editor" styleClass="page-title"/>
                    </HBox>
                    <Button text="Светлая/Тёмная" onAction="#onToggleTheme" styleClass="profile-button"/>
                    <Button text="Профиль" onAction="#onProfileClick" styleClass="profile-button"/>
                </HBox>
            </top>
            <center>
                <BorderPane fx:id="contentArea" styleClass="content-area"/>
            </center>
        </BorderPane>
    </center>
</BorderPane>
