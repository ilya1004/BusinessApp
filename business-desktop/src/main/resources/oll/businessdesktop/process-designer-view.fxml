<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.web.WebView?>
<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="oll.businessdesktop.ProcessDesignerController">
    <top>
        <ToolBar fx:id="toolBar">
            <Button text="New Diagram" onAction="#onNewDiagram"/>
            <Button text="Open .bpmn" onAction="#onOpenFile"/>
            <Button text="Save XML" onAction="#onSaveXML"/>
            <Separator/>
            <Button text="Export SVG" onAction="#onExportSVG"/>
        </ToolBar>
    </top>
    <center>
        <WebView fx:id="webView"/>
    </center>
</BorderPane>
