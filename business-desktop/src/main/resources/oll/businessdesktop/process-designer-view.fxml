<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="oll.businessdesktop.ProcessDesignerController">
    <top>
        <VBox>
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 8 15 0 15;">
                <Label fx:id="diagramNameLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label fx:id="lastSavedLabel" style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;"/>
            </HBox>
            <ToolBar fx:id="toolBar">
                <Button text="New Diagram" onAction="#onNewDiagram"/>
                <Button text="Save" onAction="#onSaveXML"/>
                <Separator/>
                <Button text="Open .bpmn" onAction="#onOpenFile"/>
                <Button text="Open from DB" onAction="#onOpenFromDb"/>
                <Separator/>
                <Button text="Export to .SVG" onAction="#onExportSVG"/>
                <Button text="Open SVG Folder" onAction="#onOpenSvgFolder"/>
                <Region HBox.hgrow="ALWAYS"/>
            </ToolBar>
        </VBox>
    </top>
    <center>
        <WebView fx:id="webView"/>
    </center>
    <right>
        <ScrollPane fitToWidth="true" styleClass="properties-panel" prefWidth="280" minWidth="280">
            <VBox spacing="10" style="-fx-padding: 15;">
                <Label text="Properties" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Separator/>
                <VBox fx:id="propertiesContainer" spacing="8">
                    <Label fx:id="noSelectionLabel" text="Select an element" style="-fx-text-fill: -color-fg-muted;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </right>
</BorderPane>
